# =============================================
# FlowDesk - Docker Compose 환경변수 (예시)
# 사용법: cp .env.example .env 후 아래 값을 실제 값으로 채우세요.
# 이 파일(.env)은 docker-compose.yml 의 ${VAR} 치환에 사용됩니다.
# ⚠️ .env 는 .gitignore 로 제외됩니다 — 절대 커밋하지 마세요.
# =============================================

# ── 네트워크 / 접속 ─────────────────────────────────────────
# 바인딩 주소: 로컬 전용은 127.0.0.1, 사내망 개방은 0.0.0.0
BIND_ADDR=127.0.0.1
# 프론트엔드 노출 포트 (HTTP→HTTPS 리다이렉트 / HTTPS)
APP_PORT=5100
APP_HTTPS_PORT=5443
# CORS·Socket.IO 허용 오리진 (서버 IP/도메인으로 변경, 콤마 구분)
# 예) https://192.168.1.100:5443,http://192.168.1.100:5100
CORS_ORIGIN=https://localhost:5443,http://localhost:5100

# ── 데이터베이스 ────────────────────────────────────────────
# DB 비밀번호 (반드시 변경 - 영문+숫자 16자 이상 권장)
DB_PASSWORD=CHANGE_THIS_DB_PASSWORD

# ── 인증 ────────────────────────────────────────────────────
# JWT 비밀키 (반드시 변경 - 무작위 64자 이상)
# 생성: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING
JWT_EXPIRES_IN=8h
# OTP 2단계 인증 건너뛰기 (개발용). 운영은 false 권장
DISABLE_OTP=false

# ── 민감정보 암호화 (AES-256-GCM) ───────────────────────────
# 32바이트(64 hex) 키. 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️ 키 분실 시 기존 암호화 데이터 복호화 불가. 운영 중 변경 금지.
DATA_ENCRYPTION_KEY=
