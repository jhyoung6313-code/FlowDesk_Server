# ── 데이터베이스 ────────────────────────────────────────────
# PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/task_manager"

# ── 인증 · 세션 (금융권 보안 정책) ──────────────────────────
JWT_SECRET="your-very-secret-key-change-this-in-production"
JWT_EXPIRES_IN="1h"            # 금융권 권고 30분~1시간
IDLE_TIMEOUT_MINUTES=30        # 유휴 세션 자동 로그아웃(분)
ENFORCE_OTP=true               # OTP 2단계 인증 전사 강제
BCRYPT_ROUNDS=12               # 비밀번호 해시 cost

# ── 민감정보 컬럼 암호화 (AES-256-GCM) ──────────────────────
# 32바이트(64 hex) 키. 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️ 절대 git 에 커밋 금지. 키 분실 시 기존 암호화 데이터 복호화 불가
DATA_ENCRYPTION_KEY=""

# ── 계정 잠금 ────────────────────────────────────────────────
LOGIN_MAX_FAILED=5
LOGIN_LOCK_MINUTES=30

# ── 비밀번호 정책 ────────────────────────────────────────────
PASSWORD_MIN_LENGTH=9
PASSWORD_MIN_CLASSES=3
PASSWORD_EXPIRE_DAYS=90
PASSWORD_HISTORY_COUNT=5

# ── 데이터 보유 · 자동 파기 ─────────────────────────────────
RETENTION_AUDIT_DAYS=1095       # 감사로그 3년(신용정보법)
RETENTION_SOFT_TASK_DAYS=90
RETENTION_NOTIFICATION_DAYS=90
RETENTION_PURGE_CRON="0 3 * * *"

# ── 비정상 접근 탐지 ─────────────────────────────────────────
ANOMALY_BULK_WINDOW=5
ANOMALY_BULK_THRESHOLD=100
ANOMALY_FORBIDDEN_WINDOW=5
ANOMALY_FORBIDDEN_THRESHOLD=10
ANOMALY_OFF_HOURS_START=0
ANOMALY_OFF_HOURS_END=6
ANOMALY_SCAN_CRON="*/5 * * * *"

PORT=4000
CORS_ORIGIN="http://localhost:3000,http://localhost"
